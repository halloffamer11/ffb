{
  "browser": {
    "browserName": "chromium",
    "isolated": false,
    "launchOptions": {
      "channel": "chrome",
      "headless": false,
      "args": [
        "--disable-web-security",
        "--disable-features=VizDisplayCompositor",
        "--no-sandbox"
      ]
    }
  },
  "server": {
    "port": 3000,
    "host": "localhost"
  },
  "capabilities": [
    "tabs",
    "pdf",
    "vision"
  ],
  "network": {
    "allowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "https://localhost:5173"
    ],
    "blockedOrigins": []
  },
  "logging": {
    "level": "info",
    "console": true
  },
  "timeout": {
    "default": 30000,
    "navigation": 60000
  }
}